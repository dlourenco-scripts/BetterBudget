# Optional local override. If blank in development, Expo Go LAN sessions auto-detect your computer's Expo host.
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:4000/api/v1

# TestFlight / production builds should set EXPO_PUBLIC_API_URL in EAS/build env.
# Example:
# EXPO_PUBLIC_API_URL=https://YOUR-APP-RUNNER-URL.awsapprunner.com/api/v1
