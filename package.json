{
  "name": "budget-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "format": "prettier --write src",
    "reinstall": "rm -rf node_modules yarn.lock && yarn install",
    "android:clean": "rm -rf android && yarn android",
    "ios:clean": "rm -rf ios && yarn ios",
    "clean": "yarn reinstall && yarn android:clean && yarn ios:clean",
    "build:release": "cd android && ./gradlew assembleRelease && cd .. && open android/app/build/outputs/apk/release",
    "build:bundle": "cd android && ./gradlew bundleRelease && cd .. && open android/app/build/outputs/bundle/release",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.1.6",
    "axios": "^1.10.0",
    "dayjs": "^1.11.19",
    "expo": "^54.0.25",
    "expo-constants": "~18.0.9",
    "expo-contacts": "~15.0.9",
    "expo-font": "~14.0.8",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
  "expo-router": "~6.0.10",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "^6.0.7",
    "formik": "^2.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-animated-spinkit": "^1.5.2",
    "react-native-calendars": "^1.1313.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-confirmation-code-field": "^8.0.1",
    "react-native-device-info": "^14.0.4",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-gifted-charts": "^1.4.65",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-progress": "^5.0.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-walkthrough-tooltip": "^1.6.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "yup": "^1.6.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.6.1",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "react-native-svg-transformer": "^1.5.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
