NODE_ENV=development
JWT_SECRET=your_jwt_secret_key
PORT=4000
TOKEN_EXPIRES_IN=7d

# AWS RDS PostgreSQL Configuration
DATABASE_URL=postgresql://username:password@your-rds-endpoint.rds.amazonaws.com:5432/betterbudget

