NODE_ENV=development
JWT_SECRET=your_jwt_secret_key
PORT=4000
TOKEN_EXPIRES_IN=7d
CORS_ORIGINS=
DATABASE_URL=
DATABASE_SSL=false
SKIP_EMAIL_VERIFICATION=false
AUTH_CODE_RESEND_COOLDOWN_SECONDS=60

# Local PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/betterbudget

# Production can use a hosted PostgreSQL URL, such as AWS RDS.
# DATABASE_URL=postgresql://username:password@your-rds-endpoint.rds.amazonaws.com:5432/betterbudget
# DATABASE_SSL=true

# Production email through AWS SES. Local development logs codes to the backend console.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@betterbudget.app
